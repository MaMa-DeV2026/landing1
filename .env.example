# ============================================================
# Environment Configuration Template
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
# ============================================================

# Server Configuration
NODE_ENV=development
PORT=3000

# ============================================================
# SECURITY - JWT Configuration
# CRITICAL: Change these values in production!
# ============================================================
JWT_SECRET=your-super-secure-jwt-secret-at-least-32-characters-long
JWT_EXPIRY=7d

# ============================================================
# SECURITY - Admin Credentials
# CRITICAL: Change the default password immediately!
# ============================================================
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_THIS_PASSWORD_IMMEDIATELY

# ============================================================
# SECURITY - Rate Limiting
# Adjust these values based on your traffic patterns
# ============================================================
# Admin login: max attempts per window
RATE_LIMIT_ADMIN_MAX=5
RATE_LIMIT_ADMIN_WINDOW_MS=900000

# Contact form: max submissions per hour
RATE_LIMIT_CONTACT_MAX=3
RATE_LIMIT_CONTACT_WINDOW_MS=3600000

# ============================================================
# CORS Configuration
# Comma-separated list of allowed origins
# Use 'none' to disable CORS entirely
# ============================================================
CORS_ORIGINS=http://localhost:3000,https://mamadweb.netlify.app

# ============================================================
# LOGGING
# Log levels: error, warn, info, debug
# ============================================================
LOG_LEVEL=info

# ============================================================
# DATABASE (for future migrations)
# ============================================================
# DATABASE_URL=postgresql://user:password@localhost:5432/mamad_portfolio
